<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Link shortener</title>
    <link rel="stylesheet" href="/styles/style.css">
    <script src="/js/get_saved_urls.js"></script>
    <script src="/js/post_url.js"></script>
</head>
<body>
    <h1>Link Shortener</h1>
    <div class="container">
        <form id="shorten_url_form">
            <input type="text" id="site_name" placeholder="Enter the name of the bookmark" required>
            <input type="text" id="original_url" placeholder="Enter URL to shorten" required>
            <input type="text" name="alias" id="alias_input" placeholder="Enter alias" required>
            <input type="date" name="date" id="date_input">
            <button id="shorten_button">Shorten</button>
        </form>
    </div>
    <input type="text" name="search" id="search_input" placeholder=" 🔍 Search saved links">
    <ul id="saved_links">
        
    </ul>
</body>
</html>